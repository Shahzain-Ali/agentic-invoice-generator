# Google Gemini API Key (get from https://aistudio.google.com/api-keys)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Gmail credentials for sending invoices
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Google Sheet ID (from your Google Sheet URL)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google credentials JSON file path
GOOGLE_CREDENTIALS_PATH=credentials.json

# wkhtmltopdf path (for PDF generation)
WKHTMLTOPDF_PATH=C:\Program Files\wkhtmltopdf\bin\wkhtmltopdf.exe

# Backend API URL
API_URL=http://localhost:8000
